# ─────────────────────────────────────────────────────────────
#  GHL Survey Mirror Server — .env.example
#  Copy to .env and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=9000
NODE_ENV=production

# Public URL of this server — injected into /tracker.js so the
# survey page knows where to POST session data
SERVER_PUBLIC_URL=https://mir.agentemp.com

# ── AWS / DynamoDB ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Unique table for this project — do NOT reuse existing tables
DYNAMODB_SESSIONS_TABLE=Survey-MirrorSessions

# ── Session Rules ─────────────────────────────────────────────
# Client heartbeat interval in ms (default 30s)
HEARTBEAT_INTERVAL_MS=30000
# Minutes with no heartbeat before session is auto-marked exited
STALE_SESSION_MINUTES=20

# ── Other Server (Automation Bot) ─────────────────────────────
# Base URL of the other server
OTHER_SERVER_BASE_URL=https://your-other-server.example.com

# Called ONCE when session starts (fire & forget)
# POST {OTHER_SERVER_BASE_URL}{OTHER_SERVER_SESSION_INIT_PATH}
# Body: { sessionId, email, phone }
OTHER_SERVER_SESSION_INIT_PATH=/api/mirror/session/start

# NOTE: OTP is NOT forwarded via outbound API call.
# OTP value is saved to DynamoDB (otp.value).
# Other server reads it via GET /api/session/:id, validates,
# then writes back result via PUT /internal/otp-status.

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins (GHL survey domain + your other server)
CORS_ALLOWED_ORIGINS=https://link.msgsndr.com,https://api.leadconnectorhq.com,http://localhost:3000

# ── Security ──────────────────────────────────────────────────
# Shared secret — other server must send this header on all
# /internal/* calls:  x-internal-secret: <value>
INTERNAL_API_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

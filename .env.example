# ─────────────────────────────────────────────────────────────
#  GHL Survey Mirror Server — .env.example
#  Copy to .env and fill in real values.
# ─────────────────────────────────────────────────────────────

# Available open ports on the AWS instance security group:
#   9000, 8765, 38117, 38111  (also 80/443 for reverse proxy)
PORT=9000
NODE_ENV=development

# ── AWS / DynamoDB ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Unique table for this project — do NOT reuse existing tables
DYNAMODB_SESSIONS_TABLE=Survey-MirrorSessions

# ── Session Rules ─────────────────────────────────────────────
HEARTBEAT_INTERVAL_MS=30000
STALE_SESSION_MINUTES=20

# ── Other Server (Mirror / Automation Server) ─────────────────
OTHER_SERVER_BASE_URL=https://your-other-server.example.com
OTHER_SERVER_SESSION_INIT_PATH=/api/mirror/session/start
OTHER_SERVER_OTP_SUBMIT_PATH=/api/mirror/otp/verify
# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://link.msgsndr.com,https://api.leadconnectorhq.com

# ── Security ──────────────────────────────────────────────────
# Used by other server when calling /api/internal/* routes
INTERNAL_API_SECRET=YOUR_STRONG_SECRET

# ── Public URL ────────────────────────────────────────────────
# Used to inject SERVER_URL into /tracker.js
SERVER_PUBLIC_URL=https://your-mirror-server.example.com
